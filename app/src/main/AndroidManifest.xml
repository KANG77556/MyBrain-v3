<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Ollama localhost와 GPT·Gemini 클라우드 API를 호출하기 위한 권한 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 13 이상 알림 권한 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 휴대전화 재부팅 완료 알림을 받기 위한 권한 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".MyBrainApplication"
        android:allowBackup="true"
        android:label="MyBrain AI"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">

        <!--
            휴대전화 Ollama 기본 API는 http://127.0.0.1:11434를 사용합니다.
            앱 코드에서는 localhost와 127.0.0.1만 허용하여 외부 평문 서버 연결을 차단합니다.
        -->

        <!-- 앱 시작 시 알림 권한을 확인한 뒤 통합 메인 화면을 엽니다. -->
        <activity
            android:name=".NotificationPermissionActivity"
            android:exported="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 기존 핵심 기능과 비상용 규칙 분석기를 보관하는 내부 메인 화면입니다. -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Ollama·GPT·Gemini 선택과 백업 기능이 포함된 사용자 메인 화면입니다. -->
        <activity
            android:name=".IntegratedMainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Ollama·GPT·Gemini와 암호화 API 키를 설정하는 내부 화면입니다. -->
        <activity
            android:name=".AiSettingsActivity"
            android:exported="false"
            android:label="MyBrain AI 설정" />

        <!-- 선택한 AI로 문장을 분석하고 결과를 확인하는 내부 화면입니다. -->
        <activity
            android:name=".AiInputActivity"
            android:exported="false"
            android:label="AI 메시지 분석" />

        <!-- 메인 화면의 백업·복원 버튼으로만 여는 내부 화면입니다. -->
        <activity
            android:name=".BackupActivity"
            android:exported="false"
            android:label="MyBrain 백업" />

        <!-- 예약된 시각에 실제 알림을 표시합니다. -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <!-- 재부팅 또는 앱 업데이트 후 저장된 알림을 자동 복구합니다. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- 홈 화면에 오늘 일정과 할 일을 표시하는 위젯입니다. -->
        <receiver
            android:name=".TodayWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>
    </application>
</manifest>
